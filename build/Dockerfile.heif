FROM emscripten/emsdk:3.1.51

WORKDIR /build

RUN apt-get update && apt-get install -y git cmake nasm && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch v1.17.6 https://github.com/strukturag/libheif.git

CMD ["bash", "-lc", "echo 'HEIF build container is scaffolded. Add the libheif Emscripten build steps here.'"]
